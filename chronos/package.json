{
  "name": "chronos",
  "version": "1.1.0",
  "description": "AI economic historian agent for digitizing historical German city directories",
  "type": "module",
  "bin": {
    "chronos": "./dist/index.js"
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "start": "tsx agent/index.ts",
    "build": "tsc && rm -rf dist/prompts && cp -r agent/prompts dist/prompts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.62.0",
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@sinclair/typebox": "^0.34.0",
    "@types/sharp": "^0.31.1",
    "dotenv": "^16.4.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
