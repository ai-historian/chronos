{
  "name": "chronos-ai-historian",
  "displayName": "Chronos — The AI Historian",
  "description": "AI-powered assistant that supports historians",
  "version": "0.1.6",
  "publisher": "AI-Historian",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ai-historian/chronos"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onCommand:chronos.startSession"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chronos.startSession",
        "title": "Chronos: Start Agent Session"
      },
      {
        "command": "chronos.showPage",
        "title": "Chronos: Show Page"
      },
      {
        "command": "chronos.init",
        "title": "Chronos: Init Workspace"
      },
      {
        "command": "chronos.importSources",
        "title": "Chronos: Import Sources"
      },
      {
        "command": "chronos.windowSetup",
        "title": "Chronos: Window Setup"
      }
    ],
    "configuration": {
      "title": "Chronos",
      "properties": {}
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package"
  },
  "dependencies": {
    "mupdf": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.110.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.25.0"
  }
}
